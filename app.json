{
  "expo": {
    "name": "SpeakEasy",
    "slug": "speakeasy",
    "scheme": "speakeasy",
    "version": "1.0.0",
    "orientation": "default",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.speakeasy.aac"
    },
    "android": {
      "package": "com.speakeasy.aac",
      "adaptiveIcon": {
        "backgroundColor": "#F7F9FC"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "expo-file-system",
        {
          "supportsOpeningDocumentsInPlace": true,
          "enableFileSharing": true
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow SpeakEasy to use the microphone so it can listen to the conversation and suggest replies.",
          "speechRecognitionPermission": "Allow SpeakEasy to recognize speech so it can suggest replies to what you hear."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
